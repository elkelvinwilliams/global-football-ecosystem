{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "noEmit": true,
    "types": [
      "node",
      "react",
      "react-dom"
    ]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "global.d.ts"
  ]
}
