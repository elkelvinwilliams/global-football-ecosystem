CHAIN_RPC_URL=http://localhost:8545
CHAIN_ID=31337
ANCHOR_CONTRACT=0x0000000000000000000000000000000000000000
ANCHOR_SIGNER_KEY=              # KMS ref in prod; local key in dev only

# AI
